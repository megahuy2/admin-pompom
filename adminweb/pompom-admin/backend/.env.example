# Đổi tên file này thành .env và điền giá trị thật trước khi chạy

# Connection string MongoDB local (mặc định khi dùng MongoDB Community + Compass)
MONGO_URI=mongodb://localhost:27017/pompom

# Cổng chạy server Express
PORT=5000

# Secret key để ký JWT token (đổi thành chuỗi ngẫu nhiên dài khi deploy thật)
JWT_SECRET=pompom-secret-key-doi-thanh-chuoi-random-that-dai
JWT_EXPIRES_IN=7d
